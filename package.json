{
  "name": "veloce",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file-if-exists=.env db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "site:encrypt": "rm -rf _site-preview && cp -r site _site-preview && node scripts/inline-site-images.mjs _site-preview && npx staticrypt@3 _site-preview/*.html --directory _site-preview --short --config false",
    "site:preview": "npx serve site",
    "video:studio": "remotion studio remotion/index.ts",
    "video:render:pitch": "remotion render remotion/index.ts VelocePitch30 out/veloce-pitch-30s.mp4"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "drizzle-orm": "^0.36.4",
    "next": "^15.0.3",
    "postgres": "^3.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.481",
    "@remotion/renderer": "4.0.481",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "drizzle-kit": "^0.28.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.0.3",
    "remotion": "4.0.481",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
